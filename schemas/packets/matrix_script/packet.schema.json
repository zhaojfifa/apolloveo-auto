{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "apolloveo://packets/matrix_script/v1",
  "title": "Matrix Script Line Packet v1",
  "description": "Envelope-conformant packet for the Matrix Script production line. Bound by docs/contracts/factory_packet_envelope_contract_v1.md and docs/contracts/factory_packet_validator_rules_v1.md.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "line_id",
    "packet_version",
    "generic_refs",
    "line_specific_refs",
    "binding",
    "evidence"
  ],
  "properties": {
    "line_id": {
      "type": "string",
      "const": "matrix_script"
    },
    "packet_version": {
      "type": "string",
      "pattern": "^v[0-9]+(\\.[0-9]+)?$"
    },
    "generic_refs": {
      "type": "array",
      "minItems": 6,
      "items": { "$ref": "#/$defs/genericRef" }
    },
    "line_specific_refs": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/lineSpecificRef" }
    },
    "binding": { "$ref": "#/$defs/binding" },
    "evidence": { "$ref": "#/$defs/evidence" },
    "metadata": { "$ref": "#/$defs/metadata" }
  },
  "$defs": {
    "genericRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref_id", "path", "version"],
      "properties": {
        "ref_id": { "type": "string", "minLength": 1 },
        "path": {
          "type": "string",
          "pattern": "^docs/contracts/factory_[a-z_]+_contract_v[0-9]+\\.md$"
        },
        "version": { "type": "string", "pattern": "^v[0-9]+(\\.[0-9]+)?$" }
      }
    },
    "lineSpecificRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref_id", "path", "version", "binds_to"],
      "properties": {
        "ref_id": {
          "type": "string",
          "enum": ["matrix_script_variation_matrix", "matrix_script_slot_pack"]
        },
        "path": {
          "type": "string",
          "pattern": "^docs/contracts/matrix_script/[a-z_]+_contract_v[0-9]+\\.md$"
        },
        "version": { "type": "string", "pattern": "^v[0-9]+(\\.[0-9]+)?$" },
        "binds_to": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "delta": {
          "type": "object",
          "description": "Optional inline delta-field declaration; full record shapes forbidden by R2."
        }
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "worker_profile_ref",
        "deliverable_profile_ref",
        "asset_sink_profile_ref",
        "capability_plan"
      ],
      "properties": {
        "worker_profile_ref": { "type": "string", "minLength": 1 },
        "deliverable_profile_ref": { "type": "string", "minLength": 1 },
        "asset_sink_profile_ref": { "type": "string", "minLength": 1 },
        "capability_plan": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/capabilityEntry" }
        }
      }
    },
    "capabilityEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "understanding",
            "subtitles",
            "dub",
            "video_gen",
            "avatar",
            "face_swap",
            "post_production",
            "pack",
            "variation",
            "speaker",
            "lip_sync"
          ]
        },
        "mode": { "type": "string" },
        "inputs": { "type": "array", "items": { "type": "string" } },
        "outputs": { "type": "array", "items": { "type": "string" } },
        "quality_hint": { "type": "string" },
        "language_hint": { "type": "string" },
        "required": { "type": "boolean" }
      },
      "not": {
        "anyOf": [
          { "required": ["vendor_id"] },
          { "required": ["model_id"] },
          { "required": ["provider"] },
          { "required": ["provider_id"] },
          { "required": ["engine_id"] }
        ]
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference_line",
        "reference_evidence_path",
        "validator_report_path",
        "ready_state"
      ],
      "properties": {
        "reference_line": { "type": "string", "const": "hot_follow" },
        "reference_evidence_path": { "type": "string", "minLength": 1 },
        "validator_report_path": { "type": "string", "minLength": 1 },
        "ready_state": {
          "type": "string",
          "enum": ["draft", "validating", "ready", "gated", "frozen"]
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "created_by": { "type": "string" },
        "notes": { "type": "string" }
      },
      "not": {
        "anyOf": [
          { "required": ["status"] },
          { "required": ["state"] },
          { "required": ["phase"] },
          { "required": ["ready"] },
          { "required": ["done"] },
          { "required": ["current_attempt"] },
          { "required": ["delivery_ready"] },
          { "required": ["final_ready"] },
          { "required": ["publishable"] }
        ]
      }
    }
  }
}
